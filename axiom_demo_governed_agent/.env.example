# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed for the "Support Triage" scenario, which deliberately uses an
# ungoverned open model (llama-3.3-70b via NVIDIA NIM) to show the guard catching an
# exfiltration a self-governing model would refuse. Leave blank to skip that scenario.
NVIDIA_API_KEY=
