# Governed-agent demo — deployment config. Copy to `.env` and fill in.
# NEVER commit .env (deploy/.gitignore excludes it).

# ── REQUIRED ────────────────────────────────────────────────────────────────
# The demo calls Claude to reason live. Without this, every run streams
# "ANTHROPIC_API_KEY not set" and the demo looks broken. This is THE launch blocker.
ANTHROPIC_API_KEY=sk-ant-...

# Public domain Caddy gets an HTTPS cert for. A DNS A record for this name must
# point at the VM's public IP before you `up`, or cert issuance fails.
DEMO_DOMAIN=demo.orivael.dev

# Email for the Let's Encrypt account (renewal/expiry notices).
ACME_EMAIL=you@orivael.dev

# ── OPTIONAL ────────────────────────────────────────────────────────────────
# Only needed for the "Support Triage" scenario, which uses an ungoverned open
# model (llama-3.3-70b via NVIDIA NIM) to show the guard catching an exfiltration.
# Leave blank to skip that scenario.
NVIDIA_API_KEY=

# Strengthens the demo's verdict-signing key. Any long random hex string. Optional.
AXIOM_MASTER_KEY=
