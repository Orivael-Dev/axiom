# AXIOM environment configuration
# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored — never commit it.
#
# Only set the variables you actually use. Most are optional with
# sensible defaults. The ONE required variable for production
# signing chains is AXIOM_MASTER_KEY.

# ════════════════════════════════════════════════════════════════
# REQUIRED — signing key for every audit / report / event token
# ════════════════════════════════════════════════════════════════
# Generate ONE 64-hex-char value and keep it stable across runs:
#   python3 -c "import secrets;print(secrets.token_hex(32))"
# Or for development you can use any 64-char string.
AXIOM_MASTER_KEY=

# ════════════════════════════════════════════════════════════════
# LLM BACKEND — pick ONE (or set multiple; whichever the entry
# point you're running needs)
# ════════════════════════════════════════════════════════════════

# --- Path A: Local Ollama (Orin Nano / laptop) — recommended
#   Used by axiom_ollama_coder, axiom_research (backend=ollama)
#   Set host to the Tailscale URL when calling the Orin from a laptop:
#     http://orin.tailnet.ts.net:11434
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:1.5b

# --- Path B: Anthropic (Claude API)
#   Used by axiom_research (backend=claude), axiom_dev_agent (Claude mode)
# ANTHROPIC_API_KEY=sk-ant-...

# --- Path C: NVIDIA NIM (legacy DSL evolution loop)
#   Used by run_axiom.py + ui.py (Streamlit) + main.py CLI
#   Get a free key from https://build.nvidia.com → API Keys
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Path D: OpenAI-compatible (any other provider)
# OPENAI_API_KEY=sk-...

# ════════════════════════════════════════════════════════════════
# DSL EVOLUTION LOOP (run_axiom.py / ui.py / main.py)
# ════════════════════════════════════════════════════════════════
# AXIOM_MODEL=meta/llama-3.3-70b-instruct
# AXIOM_MAX_ITERATIONS=10
# AXIOM_QUALITY_THRESHOLD=8.0
# AXIOM_META_DEPTH=2

# ════════════════════════════════════════════════════════════════
# FIREWALL / GUARD API server (axiom_guard_api.py)
# ════════════════════════════════════════════════════════════════
# AXIOM_HOST=0.0.0.0
# AXIOM_PORT=8001
# AXIOM_LAN_ONLY=false              # true = reject non-LAN clients
# AXIOM_LAN_PREFIX=192.168.         # network prefix when LAN_ONLY is on
# AXIOM_TRUSTED_PROXIES=             # comma-separated reverse-proxy IPs
# AXIOM_CORS_ORIGINS=                # comma-separated origins; blank = same-origin
# AXIOM_API_TOKEN=                   # bearer token for admin endpoints
# AXIOM_DEV=false                    # true = dev-mode (verbose errors)

# ════════════════════════════════════════════════════════════════
# CMAA / fleet governance (Sovereign Box SKU)
# ════════════════════════════════════════════════════════════════
# AXIOM_DEPLOYER_NAME=
# AXIOM_DEPLOYER_CONTACT=
# AXIOM_DEPLOYER_JURISDICTION=
# AXIOM_CMAA_LOG_DIR=/var/log/axiom-cmaa

# ════════════════════════════════════════════════════════════════
# OS SHIELD daemon
# ════════════════════════════════════════════════════════════════
# AXIOM_SHIELD_ACTIVE=false

# ════════════════════════════════════════════════════════════════
# PATHS (overrides — defaults are repo-relative)
# ════════════════════════════════════════════════════════════════
# AXIOM_FILES_DIR=./axiom_files
# AXIOM_PROMPTS_DIR=./prompts
# AXIOM_LOGS_DIR=./logs

# ════════════════════════════════════════════════════════════════
# DEV/TEST tuning (rarely changed)
# ════════════════════════════════════════════════════════════════
# AXIOM_CALL_DELAY=0
# AXIOM_EFFICIENCY=balanced            # balanced | thorough | quick
# AXIOM_SHARED_MEMORY_THRESHOLD=0.7
# AXIOM_MODEL_LADDER=                  # CSV of model ids, cheapest → most capable
