# Copy to .env and fill in values before running docker compose
#
# Generate AXIOM_MASTER_KEY:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# Required
AXIOM_MASTER_KEY=

# Model to serve via trtllm-serve (must be available on HuggingFace)
TRTLLM_MODEL=meta/llama-3.1-8b-instruct

# HuggingFace token (required for gated models like Llama)
HF_TOKEN=

# Your NGC org name (used for image push/pull)
NGC_ORG=your-org

# Optional: NVIDIA NIM API key for cloud fallback when GPU unavailable
NVIDIA_NIM_API_KEY=
