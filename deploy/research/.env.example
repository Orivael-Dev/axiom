# ──────────────────────────────────────────────────────────────────────
# Research Engine deploy — environment template.
# Copy to .env and fill in. Never commit the real .env.
#   cp .env.example .env
#   chmod 600 .env
# ──────────────────────────────────────────────────────────────────────

# REQUIRED — HMAC root for every signed event token. Stable forever.
# Generate once and back up out-of-band; losing it makes every prior
# signed token unverifiable.
#   $(openssl rand -hex 32)
AXIOM_MASTER_KEY=

# REQUIRED for the TLS profile — the public DNS name that points at
# this box. Add a CNAME / A record before bringing the stack up.
# Caddy uses this for ACME (Let's Encrypt) cert provisioning.
RESEARCH_HOST=research.orivael.dev

# REQUIRED for the TLS profile — Caddy basic_auth pairs. One pair per
# beta tester. Format is whitespace-separated "user $hash" pairs, all
# on a single line.
#
# Generate hashes one at a time:
#   docker run --rm caddy:2-alpine caddy hash-password
# (it prompts for the password and prints the bcrypt hash)
#
# Then assemble:
#   BETA_AUTH_HASHES="alice $2a$14$AAAA... bob $2a$14$BBBB... carol $2a$14$CCCC..."
#
# To rotate a single tester out: regenerate the env with that pair
# removed and `docker compose up -d caddy` (caddy reloads the Caddyfile).
BETA_AUTH_HASHES=

# OPTIONAL — bearer-token defense-in-depth on /api/* paths.
# When set, EVERY /api/research, /api/medical/research, /api/ledger
# request must carry: Authorization: Bearer <this value>
# Leave blank to rely solely on Caddy basic-auth. For a slow beta with
# trusted testers, blank is fine.
AXIOM_RESEARCH_TOKEN=

# ── LLM backend ───────────────────────────────────────────────────────
# Cheapest sane combo for a beta running on a CPU-only Hetzner box.
# Roughly $5-15/month for solo-founder volume; ~$30/month with ~10
# active testers.
AXIOM_BACKEND=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# Legacy OpenAI-compatible client (Prompt Evolution / DSL tabs).
# Defaults inherit from DeepSeek when set.
AXIOM_API_KEY=
AXIOM_BASE_URL=https://api.deepseek.com/v1
AXIOM_MODEL=deepseek-chat

# Alternative: NVIDIA NIM. Get the key at build.nvidia.com.
# NVIDIA_NIM_API_KEY=
# NIM_MODEL=meta/llama-3.3-70b-instruct

# Alternative: local Ollama (only if you also run Ollama on this host).
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2.5:7b
