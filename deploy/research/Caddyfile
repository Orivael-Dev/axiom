{$RESEARCH_HOST} {
    encode gzip

    # Slow-beta gate: only invited testers (with credentials in
    # BETA_AUTH_HASHES) can even SEE the page. Caddy serves the
    # WWW-Authenticate challenge; any unauthorised request returns 401
    # without ever touching the research server.
    #
    # Pairs are expanded inline from the env var by the Caddyfile
    # parser. Format: "user1 $hash1 user2 $hash2 ...".
    basic_auth {
        import_args {$BETA_AUTH_HASHES}
    }

    # Healthcheck endpoint left public so the load balancer / external
    # monitor can probe without credentials.
    @health path /api/health
    handle @health {
        reverse_proxy research:8765
    }

    # Everything else flows through the basic_auth gate (declared above)
    # and then to the research server.
    reverse_proxy research:8765 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For   {remote_host}
        # 3-min upstream timeout so long synthesis runs don't get cut.
        transport http {
            response_header_timeout 180s
            read_timeout            180s
        }
    }

    # Production-grade security headers.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        # The console uses inline <style> and inline event handlers, so
        # CSP stays permissive on this host. Tighten when the console
        # migrates to external CSS + nonce'd scripts.
        Content-Security-Policy   "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'"
        -Server
    }

    log {
        output stdout
        format json
    }
}
