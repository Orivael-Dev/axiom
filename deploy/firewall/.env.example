# Axiom Intent Firewall — production environment variables.
#
# Copy to .env and fill in. Never commit the filled-in version.
# The CloudFormation stack reads these from AWS Secrets Manager
# instead — this .env is for local docker-compose and self-hosters.

# ─── Required ─────────────────────────────────────────────────────────

# HMAC root key for signing intent verdicts. 64 hex chars (32 bytes).
# Generate: openssl rand -hex 32
AXIOM_MASTER_KEY=

# Cookie signing secret for dashboard sessions. 64+ chars.
# Generate: openssl rand -hex 32
AXIOM_FIREWALL_SESSION_SECRET=

# ─── Caddy: all three subdomains share this one Caddy ─────────────────

FIREWALL_HOST=firewall.orivael.dev

# Basic-auth pairs for research.orivael.dev (beta-tester gate).
# Generate: docker run --rm caddy:2-alpine caddy hash-password
# Escape every $ as $$ here:
#   BETA_AUTH_HASHES=alice $$2a$$14$$abc... bob $$2a$$14$$xyz...
BETA_AUTH_HASHES=

# ─── Optional: deployment URLs ────────────────────────────────────────

# Public URL the dashboard is served at. Used for Stripe Checkout
# success/cancel redirects.
AXIOM_FIREWALL_PUBLIC_URL=https://firewall.orivael.dev

# Comma-separated list of origins permitted to call /v1/guard/check
# from a browser. Empty = no CORS (server-side calls only).
# Example: AXIOM_FIREWALL_CORS_ORIGINS=https://app.example.com,https://staging.example.com
AXIOM_FIREWALL_CORS_ORIGINS=

# Directory where per-tenant SQLite files are stored. Mount this to a
# persistent volume (EFS, EBS, host bind) — losing it = losing all
# tenants.
AXIOM_FIREWALL_TENANT_DIR=/data/tenants

# ─── Optional: Stripe billing ─────────────────────────────────────────
# Leave these unset to run the Firewall in free-tier-only mode. Set
# them all to enable self-serve Indie / Team upgrades.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_INDIE=
STRIPE_PRICE_TEAM=
STRIPE_METER_INDIE=
STRIPE_METER_TEAM=

# ─── Optional: uvicorn tuning ─────────────────────────────────────────

# Workers per task. Set to 2 * vCPU on Fargate. Default 2.
UVICORN_WORKERS=2

# Bind port. ALB / Caddy connects to this internally.
UVICORN_PORT=8004
