{$FIREWALL_HOST} {
    encode gzip

    # Hard cap on request body size — defence in depth before the
    # FastAPI _BodySizeLimitMiddleware. Caddy drops connections past
    # this cap before any bytes reach the app, so a malicious large
    # POST can't exhaust uvicorn worker memory.
    request_body {
        max_size 2MB
    }

    # Reverse proxy to the Firewall app on port 8004.
    reverse_proxy firewall:8004 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For {remote_host}
    }

    # Security headers — match what AWS ALB + CloudFront would set.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        # CSP is intentionally lax for the dashboard (Jinja templates need
        # inline styles). Tighten for the public API host if separated.
        Content-Security-Policy   "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:"
        -Server
    }

    # Caddy logs to stdout in JSON for easy ingest.
    log {
        output stdout
        format json
    }
}

research.orivael.dev {
    encode gzip

    # Beta gate — credentials injected via env vars.
    # BETA_AUTH_USER=tony  BETA_AUTH_HASH=$$2a$$14$$...  (double every $ in .env)
    basic_auth {
        {$BETA_AUTH_USER} {$BETA_AUTH_HASH}
    }

    @health path /api/health
    handle @health {
        reverse_proxy axiom-research:8765
    }

    reverse_proxy axiom-research:8765 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For   {remote_host}
        transport http {
            response_header_timeout 180s
            read_timeout            180s
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Content-Security-Policy   "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'"
        -Server
    }

    log {
        output stdout
        format json
    }
}

packs.orivael.dev {
    encode gzip

    # Registry is public — no basic_auth.
    reverse_proxy axiom-packs:8005 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For   {remote_host}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        Access-Control-Allow-Origin "*"
        -Server
    }

    log {
        output stdout
        format json
    }
}

