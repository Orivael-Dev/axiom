{$FIREWALL_HOST} {
    encode gzip

    request_body {
        max_size 2MB
    }

    # Guard API surface (Orivael consoles backend) -> guard-api container.
    # CORS (*) is set by the FastAPI app, so cross-origin calls from
    # osconsole.orivael.dev pass through. No collision with the firewall's
    # own /v1/guard/* or /dashboard/os-shield routes.
    @guardapi path /guard/* /latent/* /sovereign/* /os/shield/* /vulnguard/* /agent/* /ccg/* /qrf/* /model/*
    handle @guardapi {
        reverse_proxy axiom-guard-api:8001
    }

    # Everything else -> the Firewall app on 8004.
    handle {
        reverse_proxy firewall:8004 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-For {remote_host}
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Content-Security-Policy   "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:"
        -Server
    }

    log {
        output stdout
        format json
    }
}

{$RESEARCH_HOST} {
    encode gzip

    # Beta gate — credentials injected via env vars.
    # BETA_AUTH_USER=tony  BETA_AUTH_HASH=$$2a$$14$$...  (double every $ in .env)
    basic_auth {
        {$BETA_AUTH_USER} {$BETA_AUTH_HASH}
    }

    @health path /api/health
    handle @health {
        reverse_proxy axiom-research:8765
    }

    reverse_proxy axiom-research:8765 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For   {remote_host}
        transport http {
            response_header_timeout 180s
            read_timeout            180s
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Content-Security-Policy   "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'"
        -Server
    }

    log {
        output stdout
        format json
    }
}

{$PACKS_HOST} {
    encode gzip

    # Registry is public — no basic_auth.
    reverse_proxy axiom-packs:8005 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For   {remote_host}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        Access-Control-Allow-Origin "*"
        -Server
    }

    log {
        output stdout
        format json
    }
}

{$MCP_HOST} {
    encode gzip

    # SSE connections are long-lived — set timeouts to 0 so Caddy never
    # cuts the stream mid-session. The MCP client sends a keep-alive ping
    # every 25 s so idle connections are detectable at the app layer.
    reverse_proxy axiom-mcp:8006 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-For   {remote_host}
        header_up X-Accel-Buffering no
        transport http {
            response_header_timeout 0s
            read_timeout            0s
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        # Allow claude.ai to connect cross-origin (required for web MCP client)
        Access-Control-Allow-Origin  "https://claude.ai"
        Access-Control-Allow-Headers "Authorization, Content-Type"
        -Server
    }

    log {
        output stdout
        format json
    }
}


# ── Apex landing page (static, served from /srv/orivael) ──────────────────────
orivael.dev {
    encode gzip

    root * /opt/sites/orivael
    try_files {path} {path}/index.html /index.html
    file_server

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "SAMEORIGIN"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Content-Security-Policy   "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'"
        -Server
    }

    log {
        output stdout
        format json
    }
}

# Canonical redirect: www → apex
www.orivael.dev {
    redir https://orivael.dev{uri} permanent
}

