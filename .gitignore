# AXIOM bundle exports
*.axiom.bundle

# Evolution logs and run history — ignore contents, keep the dir
logs/*
!logs/.gitkeep
.snapshots/
axiom_files/.history/
axiom_files/.snapshots/

# Internal audit files — never publish
axiom_files/.honesty/
axiom_files/.reviews/
axiom_constitutional/axiom_files/

# Private strategy / sales / patent-counsel materials.
# The README stub is tracked so the directory is discoverable;
# everything else is local-only.
docs/internal/*
!docs/internal/README.md

# Lab results — internal benchmark runs
axiom_lab/results/
axiom_lab/benchmarks/domains/*/results/

# Proprietary files — never publish
axiom_domain_seeder.py
domain_hardener.py
axiom/teacher.py
axiom/integrity_check.py
axiom_v1.8.0_export/
axiom_v1.8.0_export.zip

